# haiflow server port
PORT=3333

# Directory for session state, queues, and responses
# HAIFLOW_DATA_DIR=/tmp/haiflow

# Used by hook scripts to reach the server (defaults to PORT if unset)
# HAIFLOW_PORT=3333

# API key for bearer token authentication (required)
HAIFLOW_API_KEY=your-secret-key

# Force every session to use this cwd. When set, the cwd field in
# /session/start request bodies is ignored (and a warning is logged if it
# differs). Use this to lock all sessions to a single project root.
# HAIFLOW_CWD=/Users/me/Sites/myproject

# Whether the request body may set its own cwd. Default: true.
# Set to "false" to require HAIFLOW_CWD on the server and reject any
# request that tries to set its own cwd.
# HAIFLOW_ALLOW_REQUEST_CWD=true

# Whether to install and inject the haiflow-guardrails skill. Default: true.
# When enabled, haiflow:
#   1. installs ~/.claude/skills/haiflow-guardrails/SKILL.md on server boot
#   2. sends "/haiflow-guardrails" into each new tmux session once Claude's
#      TUI is interactive, then waits until Claude has acknowledged it
# The skill instructs Claude to refuse paths outside cwd, refuse to read
# secrets, and refuse network exfiltration. Set to "false" to disable both
# the install and the per-session injection.
# HAIFLOW_GUARDRAILS=true

# Redis URL for pipeline pub/sub (optional — falls back to direct dispatch)
# REDIS_URL=redis://localhost:6379

# n8n instance URL and API key for workflow integration
N8N_URL=http://localhost:5678
N8N_API_KEY=
